    name: Build Voxen Arcade APK

# O GitHub vai rodar esse processo toda vez que você enviar código (push) para a branch "main" ou "master"
on:
  push:
    branches:
      - main
      - master
  workflow_dispatch: # Permite que você ative a compilação manualmente se quiser

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      # 1. Baixa o código do seu repositório para a máquina virtual do GitHub
      - name: Checkout Repository
        uses: actions/checkout@v4

      # 2. Configura o Java (necessário para compilar apps Android)
      - name: Set up JDK 17
        uses: actions/setup-java@v3
        with:
          distribution: 'zulu'
          java-version: '17'

      # 3. Instala e configura o Flutter
      - name: Set up Flutter
        uses: subosito/flutter-action@v2
        with:
          flutter-version: '3.19.x' # Altere para a versão do Flutter que você usa, se preferir
          channel: 'stable'

      # 4. Baixa as dependências do seu app (como Firebase, etc.)
      - name: Install Dependencies
        run: flutter pub get

      # 5. Compila o APK em modo de liberação (Release)
      - name: Build APK
        run: flutter build apk --release

      # 6. Salva o APK gerado para que você possa baixá-lo
      - name: Upload APK Artifact
        uses: actions/upload-artifact@v4
        with:
          name: voxen-arcade-apk
          path: build/app/outputs/flutter-apk/app-release.apk
        
